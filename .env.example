# ==============================================================================
# TrueBuild Integration Platform — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================================

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=TrueBuild Integration Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-strong-random-secret-key

# ── Odoo Online ──────────────────────────────────────────────────────────────
# URL: Your Odoo instance URL (e.g., https://truebuild.odoo.com)
# DB:  Database name — usually the subdomain (e.g., truebuild)
# USERNAME: The Odoo user's email address
# PASSWORD: The API password set via Settings > Users > Change Password
ODOO_URL=https://truebuild.odoo.com
ODOO_DB=truebuild
ODOO_USERNAME=admin@truebuild.com.au
ODOO_PASSWORD=your-odoo-api-password
ODOO_TIMEOUT=30

# ── WooCommerce ──────────────────────────────────────────────────────────────
# URL: Your WooCommerce store URL (must be HTTPS)
# Consumer Key/Secret: Generated in WooCommerce > Settings > Advanced > REST API
# Webhook Secret: The secret set when creating webhooks in WooCommerce
WOO_URL=https://truebuild.com.au
WOO_CONSUMER_KEY=ck_your_consumer_key_here
WOO_CONSUMER_SECRET=cs_your_consumer_secret_here
WOO_WEBHOOK_SECRET=your-webhook-signing-secret
WOO_API_VERSION=wc/v3
WOO_TIMEOUT=30
WOO_VERIFY_SSL=true

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://truebuild:truebuild_password@localhost:5432/truebuild_sync
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# ── Celery ───────────────────────────────────────────────────────────────────
# Leave blank to use REDIS_URL as default
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── Sync Configuration ──────────────────────────────────────────────────────
PRODUCT_SYNC_INTERVAL_SECONDS=300
INVENTORY_SYNC_INTERVAL_SECONDS=300
SYNC_BATCH_SIZE=50

# ── Tax (Australia GST) ─────────────────────────────────────────────────────
GST_RATE=0.10
GST_TAX_CLASS=GST

# ── Retry Policy ─────────────────────────────────────────────────────────────
MAX_RETRIES=4
RETRY_DELAYS_SECONDS=[60, 300, 900, 3600]

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_RATE_LIMIT_REQUESTS=30
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["*"]
